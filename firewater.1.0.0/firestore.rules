rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 서울시 공무원 이메일 + 이메일 인증 완료 계정만 쓰기 허용
    function isSeoulVerified() {
      return request.auth != null
        && request.auth.token.email.matches('.*@seoul[.]go[.]kr')
        && request.auth.token.email_verified == true;
    }

    match /markerStatus/{docId} {
      allow read:  if true;                       // 지도 표시용 — 누구나 읽기
      allow write: if isSeoulVerified()
                   && request.resource.data.status in ['done', 'default'];
    }

    match /myHydrants/{docId} {
      allow read, delete: if isSeoulVerified()
                          && request.auth.uid == resource.data.userId;
      allow create:       if isSeoulVerified()
                          && request.auth.uid == request.resource.data.userId;
    }
  }
}
